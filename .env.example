# Альфа.Пульс — конфигурация (скопируйте в .env: cp .env.example .env)

# Секрет подписи JWT — в проде заменить на длинную случайную строку
JWT_SECRET=dev-secret-change-me-please

# Токен админских эндпоинтов (заголовок X-Admin-Token)
ADMIN_TOKEN=alfa-admin

# dev | prod. В dev OTP-код возвращается в ответе request-code (поле debug_code)
# и пишется в лог — для демо без настроенного Telegram-бота.
APP_ENV=dev

# Токен Telegram-бота (@BotFather). Пусто — бот выключен.
TELEGRAM_BOT_TOKEN=

# VAPID-ключи для Web Push. Сгенерировать: make vapid (и вставить сюда).
# Пусто — web push выключен.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Периодичность фонового пересчёта прогнозов (Go duration: 30m, 1h, ...)
RECALC_INTERVAL=1h

# LLM для AI-советов (OpenAI-совместимый эндпоинт: GigaChat, OpenAI, локальный
# ollama/llama.cpp). Пусто — советы работают только по правилам.
# Пример для OpenAI:   LLM_API_URL=https://api.openai.com/v1
# Пример для ollama:   LLM_API_URL=http://host.docker.internal:11434/v1
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=

# Боевой источник транзакций — API эквайринга банка. Пусто — используется CSV.
ACQUIRING_API_URL=
ACQUIRING_API_TOKEN=

# Ниже — значения для запуска БЕЗ Docker (docker-compose задаёт свои):
# DATABASE_URL=postgres://pulse:pulse@localhost:5432/pulse?sslmode=disable
# REDIS_URL=redis://localhost:6379/0
# ML_SERVICE_URL=http://localhost:8000
# HTTP_ADDR=:8080
# WEB_DIR=web/dist
